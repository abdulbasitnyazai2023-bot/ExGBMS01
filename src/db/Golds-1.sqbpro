    id INTEGER PRIMARY KEY AUTOINCREMENT,
    customer_id INTEGER NOT NULL,

    asset_type TEXT NOT NULL,      -- AFG | USD | GOLD | SILVER
    gold_form TEXT,                -- PASA | BARG | NULL

    unit TEXT NOT NULL,            -- gram | tola | mesqal | kg | currency
    transaction_type TEXT NOT NULL,-- received | paid

    amount REAL NOT NULL,

    details TEXT,
    jalali_date TEXT,

    FOREIGN KEY (customer_id) REFERENCES customers(customer_id)
)
DROP TABLE customer_statements</sql><current_tab id="0"/></tab_sql></sqlb_project>
